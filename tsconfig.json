{
  "compilerOptions": {
    "target": "es2019",
    "module": "none",
    "lib": ["es2019"],
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "node",
    "types": ["google-apps-script"],
    "skipLibCheck": true
  },
  "include": [
    "src/gas/**/*"
  ]
}
